# Copy this file to .env and fill in your values.
# Never commit .env to source control.

SECRET_KEY=change-this-to-a-long-random-string-in-production

# --- SQLite (default — works on Windows ARM, zero install required) ---
DATABASE_URL=sqlite:///callreview_poc.db

# --- PostgreSQL (production — uncomment and fill in when deploying to a real server) ---
# DATABASE_URL=postgresql://postgres:yourpassword@localhost/callreview_poc
